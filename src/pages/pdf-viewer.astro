---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="pdf-viewer-container">
    <h1 id="pdf-title">资源</h1>
    <div class="pdf-embed">
      <iframe id="pdf-iframe" width="100%" height="800px" style="border: none;"></iframe>
    </div>
    <div class="button-group">
      <a id="external-link" href="#" target="_blank" class="external-link">在新标签页中打开</a>
      <a id="download-link" href="#" class="download-link" download>下载文件</a>
    </div>
    <p class="note">如果无法正常显示，请尝试在新标签页中打开或下载文件。</p>
  </div>

  <script>
    // @ts-nocheck
    // 从 URL 参数中获取 PDF 链接和标题
    const urlParams = new URLSearchParams(window.location.search);
    let pdfUrl = urlParams.get('url');
    const pdfTitle = urlParams.get('title');

    // 将HTTP链接升级为HTTPS
    if (pdfUrl && pdfUrl.startsWith('http://')) {
      pdfUrl = pdfUrl.replace('http://', 'https://');
    }

    // 设置标题
    const titleElement = document.getElementById('pdf-title');
    if (pdfTitle && titleElement) {
      titleElement.textContent = pdfTitle;
    }

    // 设置 iframe 源
    const iframeElement = document.getElementById('pdf-iframe');
    if (pdfUrl && iframeElement) {
      // @ts-ignore
      iframeElement.src = pdfUrl;
    }

    // 设置外部链接和下载链接
    const externalLink = document.getElementById('external-link');
    const downloadLink = document.getElementById('download-link');
    if (pdfUrl) {
      // @ts-ignore
      if (externalLink) externalLink.href = pdfUrl;
      // @ts-ignore
      if (downloadLink) downloadLink.href = pdfUrl;
    }
  </script>

  <style>
    .pdf-viewer-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .pdf-viewer-container h1 {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .pdf-embed {
      border: 1px solid #ddd;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .pdf-embed iframe {
      display: block;
    }

    .button-group {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .external-link, .download-link {
      display: inline-block;
      padding: 10px 20px;
      background-color: #3498db;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      transition: background-color 0.3s;
    }

    .external-link:hover, .download-link:hover {
      background-color: #2980b9;
    }

    .note {
      text-align: center;
      margin-top: 15px;
      color: #666;
      font-size: 14px;
    }
  </style>
</BaseLayout>
