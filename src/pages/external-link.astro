<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Permissions-Policy" content="unload=(self)" />
    <title>外部链接 - NEXUS</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        overflow: hidden;
      }

      .content-container {
        width: 100vw;
        height: 100vh;
        margin: 0;
        padding: 0;
        overflow: auto;
      }

      object, embed, video, audio, iframe {
        width: 100%;
        height: 100%;
        border: none;
      }

      .error-message {
        text-align: center;
        margin-top: 50px;
        font-family: Arial, sans-serif;
        color: #333;
      }
    </style>
  </head>
  <body>
    <div class="content-container" id="content-container">
      <!-- 内容将通过 JavaScript 动态添加 -->
    </div>

    <script>
      // 解码 URL 参数
      function getEncodedUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('url');
      }

      function getEncodedTitle() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('title');
      }

      function decodeUrl(encodedUrl: string) {
        try {
          const urlDecoded = decodeURIComponent(encodedUrl);
          return urlDecoded;
        } catch (error) {
          console.error('URL 解码失败:', error);
          return null;
        }
      }

      function decodeTitle(encodedTitle: string) {
        try {
          const titleDecoded = decodeURIComponent(encodedTitle);
          return titleDecoded;
        } catch (error) {
          console.error('标题解码失败:', error);
          return '外部链接';
        }
      }

      function initContent() {
        const encodedUrl = getEncodedUrl();
        if (!encodedUrl) {
          document.body.innerHTML = '<h1 class="error-message">错误：缺少链接参数</h1>';
          return;
        }

        const originalUrl = decodeUrl(encodedUrl);
        if (!originalUrl) {
          document.body.innerHTML = '<h1 class="error-message">错误：链接解码失败</h1>';
          return;
        }

        // 解码标题并设置页面标题
        const encodedTitle = getEncodedTitle();
        if (encodedTitle) {
          const decodedTitle = decodeTitle(encodedTitle);
          document.title = decodedTitle + ' - NEXUS';
        }

        const container = document.getElementById('content-container');
        if (!container) {
          document.body.innerHTML = '<h1 class="error-message">错误：容器元素未找到</h1>';
          return;
        }

        // 静态网站直接使用原始URL
        // 注意：静态网站无法使用服务器端代理，直接访问外部资源
        const resourceUrl = originalUrl;

        // 根据文件类型选择显示方式
        const lowerUrl = originalUrl.toLowerCase();
        if (lowerUrl.endsWith('.pdf')) {
          // PDF 文件
          const object = document.createElement('object');
          object.data = resourceUrl;
          object.type = 'application/pdf';
          object.style.width = '100%';
          object.style.height = '100%';
          container.appendChild(object);
        } else if (lowerUrl.endsWith('.mp4') || lowerUrl.endsWith('.avi') || lowerUrl.endsWith('.mov') || lowerUrl.endsWith('.wmv')) {
          // 视频文件
          const video = document.createElement('video');
          video.src = resourceUrl;
          video.controls = true;
          video.autoplay = false;
          video.style.width = '100%';
          video.style.height = '100%';
          container.appendChild(video);
        } else if (lowerUrl.endsWith('.mp3') || lowerUrl.endsWith('.wav') || lowerUrl.endsWith('.ogg') || lowerUrl.endsWith('.flac')) {
          // 音频文件
          const audio = document.createElement('audio');
          audio.src = resourceUrl;
          audio.controls = true;
          audio.autoplay = false;
          audio.style.width = '100%';
          audio.style.height = '100px';
          container.appendChild(audio);
        } else {
          // 其他文件类型，使用 iframe
          const iframe = document.createElement('iframe');
          iframe.src = resourceUrl;
          iframe.style.width = '100%';
          iframe.style.height = '100%';
          iframe.style.border = '0';

          // 添加错误处理
          iframe.addEventListener('error', function(e) {
            console.error('iframe 加载错误:', e);
            container.innerHTML = `
              <div class="error-message">
                <h1>加载失败</h1>
                <p>无法加载外部链接：${escapeHtml(originalUrl)}</p>
                <p>错误：iframe 加载失败</p>
                <button onclick="window.location.reload()">重试</button>
                <button onclick="window.close()">关闭窗口</button>
              </div>
            `;
          });

          container.appendChild(iframe);
        }

        // 添加全局错误处理
        window.addEventListener('error', function(e) {
          console.error('全局错误:', e);
          // 只处理与外部资源加载相关的错误
          if (e.target instanceof HTMLElement && (e.target.tagName === 'IFRAME' || e.target.tagName === 'OBJECT')) {
            const container = document.getElementById('content-container');
            if (container) {
              container.innerHTML = `
                <div class="error-message">
                  <h1>加载失败</h1>
                  <p>无法加载外部资源</p>
                  <p>错误：${escapeHtml(e.message)}</p>
                  <button onclick="window.location.reload()">重试</button>
                  <button onclick="window.close()">关闭窗口</button>
                </div>
              `;
            }
          }
        });

        // 辅助函数：转义HTML特殊字符
        function escapeHtml(text: string): string {
          const div = document.createElement('div');
          div.textContent = text;
          return div.innerHTML;
        }
      }

      // 初始化
      initContent();
    </script>
  </body>
</html>
