<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>外部链接 - NEXUS</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        overflow: hidden;
      }

      .proxy-container {
        width: 100vw;
        height: 100vh;
        margin: 0;
        padding: 0;
        overflow: hidden;
      }

      .proxy-iframe {
        width: 100%;
        height: 100%;
        border: none;
        margin: 0;
        padding: 0;
      }

      .error-message {
        text-align: center;
        margin-top: 50px;
        font-family: Arial, sans-serif;
        color: #333;
      }
    </style>
  </head>
  <body>
    <div class="proxy-container">
      <iframe id="proxy-iframe" class="proxy-iframe" src="" title="外部链接内容"></iframe>
    </div>

    <script>
      // 解码 URL 参数
      function getEncodedUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('url');
      }
      
      function getEncodedTitle() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('title');
      }
      
      function decodeUrl(encodedUrl: string) {
        try {
          // 直接 URL 解码
          const urlDecoded = decodeURIComponent(encodedUrl);
          return urlDecoded;
        } catch (error) {
          console.error('URL 解码失败:', error);
          return null;
        }
      }
      
      function decodeTitle(encodedTitle: string) {
        try {
          // 直接 URL 解码
          const titleDecoded = decodeURIComponent(encodedTitle);
          return titleDecoded;
        } catch (error) {
          console.error('标题解码失败:', error);
          return '外部链接';
        }
      }
      
      function initProxy() {
        const encodedUrl = getEncodedUrl();
        if (!encodedUrl) {
          document.body.innerHTML = '<h1 class="error-message">错误：缺少链接参数</h1>';
          return;
        }
        
        const originalUrl = decodeUrl(encodedUrl);
        if (!originalUrl) {
          document.body.innerHTML = '<h1 class="error-message">错误：链接解码失败</h1>';
          return;
        }
        
        // 解码标题并设置页面标题
        const encodedTitle = getEncodedTitle();
        if (encodedTitle) {
          const decodedTitle = decodeTitle(encodedTitle);
          document.title = decodedTitle + ' - NEXUS';
        }
        
        const iframe = document.getElementById('proxy-iframe') as HTMLIFrameElement;
        if (iframe) {
          // 直接使用原始链接，不使用代理
          iframe.src = originalUrl;
        }
      }

      // 初始化
      initProxy();
    </script>
  </body>
</html>
