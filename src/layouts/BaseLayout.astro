<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NEXUS - 人类文明记载</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.4/dist/katex.min.css" integrity="sha384-vKruj+a13U8yHIkAyGgK1J3ArTLzrFGBbBc0tDp4ad/EyewESeXE/Iv67Aj8gKZ0" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/entity-styles.css" />
    <style>
      /* 弹窗样式 */
      .cc-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s, visibility 0.3s;
      }

      .cc-modal.show {
        opacity: 1;
        visibility: visible;
      }

      .cc-modal-content {
        background-color: #fff;
        border-radius: 8px;
        padding: 20px;
        max-width: 800px;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        position: relative;
      }

      .cc-close {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
      }

      .cc-close:hover {
        color: #000;
      }

      /* 媒体查看器模态框 */
      .media-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.9);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 2000;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s, visibility 0.3s;
      }

      .media-modal.show {
        opacity: 1;
        visibility: visible;
      }

      .media-modal-content {
        width: 90%;
        height: 90%;
        max-width: 1200px;
        max-height: 90vh;
        background-color: #fff;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      .media-modal-header {
        padding: 15px 20px;
        background-color: #f5f5f5;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
      }

      .media-modal-title {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: #333;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .media-modal-close {
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: #666;
        padding: 0 5px;
        line-height: 1;
        margin-left: 15px;
      }

      .media-modal-close:hover {
        color: #000;
      }

      .media-modal-body {
        flex: 1;
        overflow: hidden;
        background-color: #000;
      }

      .media-modal-body iframe,
      .media-modal-body video,
      .media-modal-body audio {
        width: 100%;
        height: 100%;
        border: none;
      }

      .media-modal-body audio {
        height: auto;
        position: relative;
        top: 50%;
        transform: translateY(-50%);
      }

      /* 事件和关系列表样式 */
      .events-list, .relations-list {
        margin-top: 15px;
      }

      .event-item, .relation-item {
        background-color: #f9f9f9;
        border-radius: 6px;
        padding: 15px;
        margin-bottom: 10px;
        border-left: 4px solid #3498db;
      }

      .relation-item {
        border-left-color: #2ecc71;
      }

      .event-item h4, .relation-item h4 {
        margin-top: 0;
        margin-bottom: 10px;
        color: #333;
      }

      .event-item p, .relation-item p {
        margin: 5px 0;
        line-height: 1.4;
      }

      /* 响应式设计 */
      @media (max-width: 768px) {
        .cc-modal-content {
          max-width: 90%;
          max-height: 90vh;
        }
        .media-modal-content {
          width: 95%;
          height: 95%;
        }
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chinese-lunar-calendar@1.0.1/dist/index.js"></script>
  </head>
  <body>
    <!-- 背景粒子效果 -->
    <iframe src="/screencode.html" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; border: none; z-index: -1; pointer-events: none;"></iframe>

    <header class="header">
      <div class="container">
        <h1 class="logo">NEXUS</h1>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/文明根基/">文明根基</a>
          <a href="/演进轨迹/">演进轨迹</a>
          <a href="/制度与创造/">制度与创造</a>
          <a href="/主体与未来/">主体与未来</a>
        </nav>
        <button class="theme-toggle" id="themeToggle" aria-label="切换主题">
          <span class="theme-icon">🌞</span>
        </button>
      </div>
    </header>

    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="footer">
      <div class="container">
        <p>© 2026 NEXUS 人类文明记载</p>
        <p>秉中 · 纳洪 · 守贞</p>
      </div>
    </footer>

    <script>
      // @ts-nocheck
      // 主题切换逻辑
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        const themeIcon = themeToggle.querySelector('.theme-icon');
        if (themeIcon) {
          // 初始化主题
          const savedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', savedTheme);
          themeIcon.textContent = savedTheme === 'dark' ? '🌞' : '🌙';

          // 切换主题
          themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            themeIcon.textContent = newTheme === 'dark' ? '🌞' : '🌙';
          });
        }
      }

      // 媒体查看器模态框管理
      let mediaModal = null;
      let currentMediaElement = null;

      function ensureMediaModal() {
        if (mediaModal) return mediaModal;

        mediaModal = document.createElement('div');
        mediaModal.id = 'media-modal';
        mediaModal.className = 'media-modal';
        mediaModal.innerHTML = `
          <div class="media-modal-content">
            <div class="media-modal-header">
              <h3 class="media-modal-title" id="media-modal-title"></h3>
              <button class="media-modal-close" id="media-modal-close" aria-label="关闭">×</button>
            </div>
            <div class="media-modal-body" id="media-modal-body"></div>
          </div>
        `;
        document.body.appendChild(mediaModal);

        const closeBtn = mediaModal.querySelector('#media-modal-close');
        if (closeBtn) {
          closeBtn.addEventListener('click', closeMediaModal);
        }

        mediaModal.addEventListener('click', (e) => {
          if (e.target === mediaModal) closeMediaModal();
        });

        window.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeMediaModal();
        });

        return mediaModal;
      }

      function closeMediaModal() {
        if (!mediaModal) return;

        if (currentMediaElement) {
          if (currentMediaElement.tagName === 'VIDEO' || currentMediaElement.tagName === 'AUDIO') {
            currentMediaElement.pause();
          }
          currentMediaElement = null;
        }

        const body = document.getElementById('media-modal-body');
        if (body) body.innerHTML = '';

        mediaModal.classList.remove('show');
      }

      function showMediaModal(title, content, mediaElement) {
        const modal = ensureMediaModal();
        const titleEl = document.getElementById('media-modal-title');
        const bodyEl = document.getElementById('media-modal-body');

        if (titleEl) titleEl.textContent = title;
        if (bodyEl) bodyEl.innerHTML = content;

        currentMediaElement = mediaElement || null;
        modal.classList.add('show');
      }

      // 处理PDF链接
      // @ts-ignore
      function handlePdfLink(url, title) {
        const container = document.createElement('div');
        container.style.cssText = 'width: 100%; height: 100%; display: flex; flex-direction: column;';

        const iframe = document.createElement('iframe');
        iframe.src = url;
        iframe.style.cssText = 'width: 100%; flex: 1; border: none;';

        const fallbackDiv = document.createElement('div');
        fallbackDiv.style.cssText = 'display: none; padding: 40px; text-align: center; background: #fff; color: #333; flex: 1;';
        fallbackDiv.innerHTML = `
          <h3 style="margin-bottom: 20px;">无法直接嵌入显示</h3>
          <p style="margin-bottom: 20px;">由于浏览器安全限制，该资源无法直接在页面中嵌入显示。</p>
          <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
            <a href="${url}" target="_blank" style="display: inline-block; padding: 10px 20px; background-color: #3498db; color: white; text-decoration: none; border-radius: 4px;">在新标签页中打开</a>
            <a href="${url}" download style="display: inline-block; padding: 10px 20px; background-color: #27ae60; color: white; text-decoration: none; border-radius: 4px;">下载文件</a>
          </div>
        `;

        container.appendChild(iframe);
        container.appendChild(fallbackDiv);

        iframe.onerror = function() {
          iframe.style.display = 'none';
          fallbackDiv.style.display = 'flex';
          fallbackDiv.style.flexDirection = 'column';
          fallbackDiv.style.justifyContent = 'center';
        };

        let loadTimeout = setTimeout(() => {
          iframe.style.display = 'none';
          fallbackDiv.style.display = 'flex';
          fallbackDiv.style.flexDirection = 'column';
          fallbackDiv.style.justifyContent = 'center';
        }, 5000);

        iframe.onload = function() {
          clearTimeout(loadTimeout);
        };

        showMediaModal(title, '', iframe);
        const body = document.getElementById('media-modal-body');
        if (body) {
          body.style.backgroundColor = '#000';
          body.appendChild(container);
        }
      }

      // 处理视频链接
      // @ts-ignore
      function handleVideoLink(url, title) {
        const video = document.createElement('video');
        video.controls = true;
        video.style.width = '100%';
        video.style.height = '100%';

        const source = document.createElement('source');
        source.src = url;

        const extension = url.split('.').pop().toLowerCase();
        if (extension === 'mp4') {
          source.type = 'video/mp4';
        } else if (extension === 'webm') {
          source.type = 'video/webm';
        } else if (extension === 'ogg') {
          source.type = 'video/ogg';
        } else {
          source.type = 'video/mp4';
        }

        video.appendChild(source);
        video.innerHTML += '您的浏览器不支持视频标签。';

        showMediaModal(title, '', video);
        const body = document.getElementById('media-modal-body');
        if (body) body.appendChild(video);

        video.play().catch(err => {
          console.log('视频需要用户交互才能播放');
        });
      }

      // 处理音频链接
      // @ts-ignore
      function handleAudioLink(url, title) {
        const audio = document.createElement('audio');
        audio.controls = true;
        audio.style.width = '100%';

        const source = document.createElement('source');
        source.src = url;

        const extension = url.split('.').pop().toLowerCase();
        if (extension === 'mp3') {
          source.type = 'audio/mpeg';
        } else if (extension === 'wav') {
          source.type = 'audio/wav';
        } else if (extension === 'flac') {
          source.type = 'audio/flac';
        } else if (extension === 'ogg') {
          source.type = 'audio/ogg';
        } else if (extension === 'm4a') {
          source.type = 'audio/mp4';
        } else {
          source.type = 'audio/mpeg';
        }

        audio.appendChild(source);
        audio.innerHTML += '您的浏览器不支持音频标签。';

        showMediaModal(title, '', audio);
        const body = document.getElementById('media-modal-body');
        if (body) {
          body.style.backgroundColor = '#fff';
          body.style.display = 'flex';
          body.style.alignItems = 'center';
          body.style.justifyContent = 'center';
          body.style.padding = '40px';
          body.appendChild(audio);
        }

        audio.play().catch(err => {
          console.log('音频需要用户交互才能播放');
        });
      }

      // 将HTTP链接升级为HTTPS
      // @ts-ignore
      function upgradeToHttps(url) {
        if (url && url.startsWith('http://')) {
          return url.replace('http://', 'https://');
        }
        return url;
      }

      // 链接处理逻辑
      document.addEventListener('DOMContentLoaded', function() {
        const links = document.querySelectorAll('a');

        links.forEach(link => {
          const href = link.getAttribute('href');
          if (!href) return;

          const processedHref = upgradeToHttps(href);
          if (processedHref !== href) {
            link.setAttribute('href', processedHref);
          }

          const isPdf = processedHref.toLowerCase().endsWith('.pdf');
          const isVideo = /\.(mp4|webm|ogg|mov|avi|wmv)$/i.test(processedHref);
          const isAudio = /\.(mp3|wav|flac|ogg|m4a|wma)$/i.test(processedHref);
          const isExternal = /^https?:\/\//i.test(processedHref) && !processedHref.includes(window.location.hostname);

          if (isPdf) {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              let title = link.textContent.trim() || 'PDF文档';
              title = title.replace(/^打开：+/g, '');
              handlePdfLink(processedHref, title);
            });
          } else if (isVideo) {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              let title = link.textContent.trim() || '视频';
              title = title.replace(/^打开：+/g, '');
              handleVideoLink(processedHref, title);
            });
          } else if (isAudio) {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              let title = link.textContent.trim() || '音频';
              title = title.replace(/^打开：+/g, '');
              handleAudioLink(processedHref, title);
            });
          } else if (isExternal) {
            link.addEventListener('click', function(e) {
              e.preventDefault();
              let title = link.textContent.trim() || '外部链接';
              title = title.replace(/^打开：+/g, '');
              handlePdfLink(processedHref, title);
            });
          }
        });
      });

      // 实体标签点击弹窗（显示对应 *.events.json 与 *.relations.json 内容）
      document.addEventListener('DOMContentLoaded', function() {
        interface Window {
          __ANNOTATION_DATA__?: { files: { path: string; content: string }[] };
        }

        let annotationData: { files: { path: string; content: string }[] } = { files: [] };

        if (typeof window !== 'undefined' && (window as Window).__ANNOTATION_DATA__) {
          annotationData = (window as Window).__ANNOTATION_DATA__ || { files: [] };
          console.log('加载的标注文件数量：', annotationData.files?.length || 0);
          console.log('加载的标注文件：', annotationData.files);
        } else {
          console.warn('未找到页面注释数据');
        }

        function escapeHtml(str: string): string {
          return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function ensureModal(): HTMLElement {
          let m = document.getElementById('cc-entity-modal') as HTMLElement | null;
          if (m) return m;
          m = document.createElement('div');
          m.id = 'cc-entity-modal';
          m.className = 'cc-modal';
          m.innerHTML = `<div class="cc-modal-content">` +
                        `<button class="cc-close" aria-label="关闭">×</button>` +
                        `<div id="cc-entity-modal-body"></div>` +
                        `</div>`;
          document.body.appendChild(m);
          const closeBtn = m.querySelector('.cc-close') as HTMLElement | null;
          if (closeBtn) {
            closeBtn.addEventListener('click', () => m.classList.remove('show'));
          }
          m.addEventListener('click', (e) => { if (e.target === m) m.classList.remove('show'); });
          window.addEventListener('keydown', (e) => { if (e.key === 'Escape') m.classList.remove('show'); });
          return m;
        }

        function showEntityModal(html: string): void {
          const modal = ensureModal();
          const body = document.getElementById('cc-entity-modal-body') as HTMLElement | null;
          if (body) body.innerHTML = html;
          modal.classList.add('show');
        }

        function buildEntityDetail(entityKey: string | null, entityName: string): string | null {
          const matchedEvents: any[] = [];
          const matchedRelations: any[] = [];
          const needles = [entityName];
          if (entityKey && entityKey !== entityName) {
            needles.push(entityKey);
          }

          // 关系类型映射表
          const relationTypeMap: { [key: string]: string } = {
            'born_in': '出生于',
            'inventor_of': '发明',
            'taught': '教导',
            'ruler_of': '统治',
            'founder_of': '创立',
            'moved_to': '迁移至',
            'constructed': '建造',
            'descendant_of': '后裔',
            'occupies': '居住于',
            'established': '建立',
            'enabled': '促成',
            'affected_by': '受影响',
            'expansion_to': '扩展至',
            'participates_in': '参与',
            'occurs_in': '发生于',
            'occurs_on': '发生时间',
            'same_as': '等同于',
            'part_of': '属于',
            'precedes': '先于',
            'supports': '支持',
            'elaborates': '详述',
            'cites': '引用',
            'refers_to': '引用',
            'caused_by': '由...引起',
            'migrated_to': '迁移至'
          };

          // 获取友好的关系类型名称
          function getFriendlyRelationType(type: string): string {
            return relationTypeMap[type] || type;
          }

          // 清理实体标识符
          function cleanEntityIdentifier(identifier: string): string {
            // 移除前缀，如 entity:person:、event:science:等
            let cleaned = identifier.replace(/^(entity|event):\w+:/, '');
            // 替换下划线为空格
            cleaned = cleaned.replace(/_/g, ' ');
            return cleaned;
          }

          console.log('搜索关键词：', needles);
          console.log('标注文件数量：', annotationData.files?.length || 0);

          if (!needles.length || !needles[0]) return null;

          const idxCompare = (text: string, needle: string): boolean => {
            const l = text.toLowerCase();
            const n = needle.toLowerCase();
            return l.includes(n);
          };

          // 搜索所有标注文件
          for (const file of annotationData.files || []) {
            console.log('检查文件：', file.path);
            try {
              // 解析JSON内容
              const data = JSON.parse(file.content);

              if (file.path.endsWith('.events.json')) {
                // 检查事件文件
                for (const event of data) {
                  // 检查事件中是否包含关键词
                  const eventText = JSON.stringify(event).toLowerCase();
                  for (const needle of needles) {
                    if (idxCompare(eventText, needle.toLowerCase())) {
                      matchedEvents.push(event);
                      break;
                    }
                  }
                }
              } else if (file.path.endsWith('.relations.json')) {
                // 检查关系文件
                for (const relation of data) {
                  // 检查关系中是否包含关键词
                  const relationText = JSON.stringify(relation).toLowerCase();
                  for (const needle of needles) {
                    if (idxCompare(relationText, needle.toLowerCase())) {
                      matchedRelations.push(relation);
                      break;
                    }
                  }
                }
              }
            } catch (error) {
              console.error('解析JSON文件失败：', file.path, error);
            }
          }

          console.log('匹配事件数量：', matchedEvents.length);
          console.log('匹配关系数量：', matchedRelations.length);

          if (!matchedEvents.length && !matchedRelations.length) {
            return `<p>未找到与 <strong>${escapeHtml(entityName)}</strong> 匹配的事件/关系内容。</p>`;
          }

          let out = `<h2>实体：${escapeHtml(entityName)}</h2>`;

          // 显示匹配的事件
          if (matchedEvents.length) {
            out += `<h3>相关事件</h3>`;
            out += `<div class="events-list">`;
            for (const event of matchedEvents) {
              out += `<div class="event-item">`;
              out += `<h4>${escapeHtml(event.title || '无标题')}</h4>`;
              if (event.time_text) {
                out += `<p><strong>时间：</strong>${escapeHtml(event.time_text)}</p>`;
              }
              if (event.year) {
                out += `<p><strong>年份：</strong>${escapeHtml(event.year.toString())}</p>`;
              }
              if (event.people && event.people.length) {
                out += `<p><strong>人物：</strong>${event.people.map((p: string) => escapeHtml(p)).join('、')}</p>`;
              }
              if (event.places && event.places.length) {
                out += `<p><strong>地点：</strong>${event.places.map((p: string) => escapeHtml(p)).join('、')}</p>`;
              }
              if (event.summary) {
                out += `<p><strong>概述：</strong>${escapeHtml(event.summary)}</p>`;
              }
              out += `</div>`;
            }
            out += `</div>`;
          }

          // 显示匹配的关系
          if (matchedRelations.length) {
            out += `<h3>相关关系</h3>`;
            out += `<div class="relations-list">`;
            for (const relation of matchedRelations) {
              out += `<div class="relation-item">`;
              out += `<h4>${escapeHtml(getFriendlyRelationType(relation.type || '无类型'))}</h4>`;
              if (relation.source) {
                out += `<p><strong>来源：</strong>${escapeHtml(cleanEntityIdentifier(relation.source))}</p>`;
              }
              if (relation.target) {
                out += `<p><strong>目标：</strong>${escapeHtml(cleanEntityIdentifier(relation.target))}</p>`;
              }
              if (relation.note) {
                out += `<p><strong>说明：</strong>${escapeHtml(relation.note)}</p>`;
              }
              out += `</div>`;
            }
            out += `</div>`;
          }

          return out;
        }

        document.body.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (!target) return;
          const span = target.closest('[class^="entity-"]') as HTMLElement;
          if (!span) return;
          e.preventDefault();

          const canonical = span.getAttribute('data-canonical');
          const text = (span.textContent || '').trim();
          const html = buildEntityDetail(canonical || text, text);
          if (html) showEntityModal(html);
        });
      });
    </script>
  </body>
</html>
